DATABASE_URL=postgresql://health:password@localhost:5432/health
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://health.yourdomain.com/api/auth/google/callback
GOOGLE_DRIVE_CALLBACK_URL=https://health.yourdomain.com/api/auth/google/drive/callback
JWT_SECRET=generate-a-long-random-string
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@yourdomain.com
NODE_ENV=production
PORT=3000
BASE_URL=https://health.yourdomain.com
# Must match BASE_URL. Used for CSRF Origin checks and for building the link
# in password-reset emails. If unset, password-reset links fall back to a
# hardcoded production domain and will be wrong on other deployments.
APP_URL=https://health.yourdomain.com
# Optional: Resend (https://resend.com) API key for sending password-reset
# emails. If unset, the reset link is only logged to the server console
# (logs/app.log) instead of being emailed to the user.
RESEND_API_KEY=
RESEND_FROM=BP & BMI <no-reply@yourdomain.com>
